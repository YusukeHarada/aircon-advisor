rules_version = '2';

// 要件定義書 9章「Firestoreセキュリティルール」に対応。
// users/{uid}/* は本人のみ読み書き可。weather_cache/* は認証済みユーザーであれば
// 読み取り可、書き込みはサーバー側（Admin SDK、ルール適用対象外）のみに限定する。
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /weather_cache/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK（サーバー側）経由のみ。クライアントからの書き込みは禁止。
    }
  }
}
